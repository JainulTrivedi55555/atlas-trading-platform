[Unit]
Description=ATLAS Trading Signal API (FastAPI + Uvicorn)
After=network.target
Wants=network.target

[Service]
Type=simple
User=jainultrivedi22222
WorkingDirectory=/home/jainultrivedi22222/atlas-trading-platform
Environment="PATH=/home/jainultrivedi22222/miniconda3/envs/fintech/bin"
EnvironmentFile=/home/jainultrivedi22222/atlas-trading-platform/.env
ExecStart=/home/jainultrivedi22222/miniconda3/envs/fintech/bin/uvicorn \
    app.main:app \
    --host 0.0.0.0 \
    --port 8000 \
    --workers 2 \
    --log-level info
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
